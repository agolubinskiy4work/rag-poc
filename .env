OLLAMA_BASE_URL=http://localhost:11434

# Models
EMBEDDING_MODEL=nomic-embed-text
GENERATION_MODEL=llama3.1:8b

# Qdrant (running via docker compose)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=rag_chunks
EMBEDDING_DIM=768

# Chunking
CHUNK_SIZE=1200
CHUNK_OVERLAP=200

# Retrieval
DENSE_TOP_K=12
LEXICAL_TOP_K=12
FINAL_TOP_K=8
MIN_FUSED_SCORE=0.08
MIN_TERM_OVERLAP=1

# Local paths
DATA_DIR=data
UPLOADS_DIR=data/uploads
CACHE_DIR=data/cache
LOGS_DIR=data/logs
SQLITE_PATH=data/cache/metadata.db
